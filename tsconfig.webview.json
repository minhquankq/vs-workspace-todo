{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": ["webview", "src/types.ts"],
  "exclude": ["node_modules", "dist", "src/extension.ts", "src/storage.ts", "src/TodoViewProvider.ts"]
}
